        <div class="custom-html"><div>
    <div class="cmp-custom__html__wrapper" id="reinvent-hero">
    	<div class="html_content" htmlcontent="&lt;!-- Hero Custom component start -->
&lt;section id=&#34;hero_custom&#34; class=&#34;hero_custom&#34;>
  &lt;video aria-hidden=&#34;true&#34; role=&#34;presentation&#34; class=&#34;hero_custom__background hero_custom__background--video&#34;
    webkit-playsinline=&#34;true&#34; playsinline=&#34;true&#34; loop=&#34;true&#34; autoplay=&#34;true&#34; muted=&#34;true&#34;
    poster=&#34;/content/dam/system-files/acom/custom-code/change-more/imagery/custom-hero-poster.png&#34;>
    &lt;source src=&#34;/content/dam/system-files/acom/custom-code/change-more/media/custom-rad-hero-bg-video.mp4&#34;
      type=&#34;video/mp4&#34; />
  &lt;/video>
  &lt;div id=&#34;hero_headline_h1&#34;>
    &lt;h1>Together We Reinvented&lt;/h1>
  &lt;/div>
  &lt;a class=&#34;hero_custom__cta_1&#34; href=&#34;https://www.accenture.com/jp-ja/insights/strategy/reinvented-with-accenture&#34; target=&#34;_self&#34; data-analytics-link-name=&#34;事例を見る&#34; title=&#34;事例を見る&#34;
    data-analytics-module-name=&#34;front-pagehero-1&#34; data-analytics-template-zone=&#34;front-page-hero&#34;
    data-analytics-link-type=&#34;engagement&#34; data-barba-transition>
    &lt;div class=&#34;hero_custom__grid&#34;>
      &lt;p class=&#34;hero_custom__headline&#34;>
        &lt;span class=&#34;hero_custom__headline__text hero_custom__headline__text--left&#34; role=&#34;presentation&#34;
          aria-hidden=&#34;true&#34;>Together We&lt;/span>
        &lt;span class=&#34;hero_custom__headline__text hero_custom__headline__text--right&#34; role=&#34;presentation&#34;
          aria-hidden=&#34;true&#34;>
          &lt;span>Rein&lt;/span>
          &lt;svg class=&#34;hero_custom__headline__text--V&#34; viewBox=&#34;0 0 107 118&#34; xmlns=&#34;http://www.w3.org/2000/svg&#34;>
            &lt;path d=&#34;M0 118L107 74.4053V43.5947L0 0V30.8107L69.1887 59L0 87.1893V118Z&#34; />
          &lt;/svg>
          &lt;span>ented&lt;/span>
        &lt;/span>
      &lt;/p>
      &lt;article class=&#34;hero_custom__body&#34;>
        &lt;div role=&#34;presentation&#34; aria-hidden=&#34;true&#34; class=&#34;hero_custom__body__border&#34;>&lt;/div>
        &lt;div class=&#34;hero_custom__body__hero_text&#34;>
          &lt;p class=&#34;hero_custom__body__hero_text__title&#34;>
          新しいサプライチェーン、Wowを生む体験、満員のスタジアム、美味しい食べ物、素敵な洋服、カッコいい車、快適な家、安らかに過ごす休日、すくすく育つ木々…私たちとなら何でも再創造できる。
          &lt;/p>

          &lt;div class=&#34;hero_cta_2&#34;>
            &lt;span class=&#34;cta_span&#34;>事例を見る&lt;/span>
            &lt;div class=&#34;hero_custom__cta__icon&#34; role=&#34;presentation&#34; aria-hidden=&#34;true&#34;>
              &lt;svg xmlns=&#34;http://www.w3.org/2000/svg&#34; viewBox=&#34;0 0 20 20&#34;>
                &lt;path d=&#34;M8.16667 15L7 13.8333L10.8333 10L7 6.16667L8.16667 5L13.1667 10L8.16667 15Z&#34; />
              &lt;/svg>
            &lt;/div>
          &lt;/div>
        &lt;/div>
      &lt;/article>

    &lt;/div>
  &lt;/a>
  &lt;button class=&#34;hero_custom__video_button&#34; title=&#34;Pause background video&#34; aria-hidden>
    &lt;svg class=&#34;hero_custom__video_button--pause&#34; width=&#34;14&#34; height=&#34;14&#34; viewBox=&#34;0 0 14 14&#34;
      xmlns=&#34;http://www.w3.org/2000/svg&#34;>
      &lt;path d=&#34;M8 14V0H14V14H8ZM0 14V0H6V14H0Z&#34;>&lt;/path>
    &lt;/svg>
    &lt;svg class=&#34;hero_custom__video_button--play hero_custom__video_button--hidden&#34; width=&#34;24&#34; height=&#34;24&#34;
      viewBox=&#34;0 0 24 24&#34; xmlns=&#34;http://www.w3.org/2000/svg&#34;>
      &lt;path d=&#34;M6.5 19V5L17.5 12L6.5 19Z&#34;>&lt;/path>
    &lt;/svg>
  &lt;/button>

  &lt;script async>
